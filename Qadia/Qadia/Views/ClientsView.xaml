<UserControl x:Class="Qadia.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1180"
             FlowDirection="RightToLeft">
             
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="HoverGreen" Color="#059669"/>
        <SolidColorBrush x:Key="TextDark" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextGray" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderGray" Color="#E5E7EB"/>

        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="15" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bgBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bgBorder" Property="Background" Value="{StaticResource HoverGreen}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bgBorder" Property="Background" Value="#047857"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="50" CenterY="20"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}" Foreground="#94A3B8" Margin="12,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dialog Styles -->
        <SolidColorBrush x:Key="DialogHeaderBg" Color="#1F2937"/>
        <SolidColorBrush x:Key="ErrorRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#059669"/>

        <Style x:Key="DialogTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F9FAFB">
        <!-- Main Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- 1. Top Navigation Bar (matching image) -->
        <Border Grid.Row="0" Background="White" Padding="24,12" BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Title & Hamburger -->
                    <ColumnDefinition Width="*"/>    <!-- Search Box -->
                    <ColumnDefinition Width="Auto"/> <!-- Add Button -->
                </Grid.ColumnDefinitions>

                <!-- Right Side: Title and Menu -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="☰" FontSize="20" Foreground="{StaticResource TextDark}" Margin="0,0,16,0" Cursor="Hand"/>
                    <TextBlock Text="إدارة الموكلين" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Middle: Long Search Box -->
                <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="20" Margin="48,0" Height="40" MaxWidth="600" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" Foreground="#64748B" VerticalAlignment="Center" Grid.Column="0" Margin="16,0,0,0"/>
                        <TextBox Grid.Column="1" 
                                 Style="{StaticResource SearchTextBox}"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="البحث عن موكل (الاسم، رقم الهاتف، أو الرقم القومي)"/>
                    </Grid>
                </Border>

                <!-- Left Side: Add Button (Vibrant Green) -->
                <Button Grid.Column="2" Style="{StaticResource ActionButton}" Background="#4ADE80" Padding="24,10" Command="{Binding AddClientCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="إضافة موكل جديد" FontSize="14" FontWeight="Bold" Margin="0,0,12,0"/>
                        <TextBlock Text="👤+" FontSize="18" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,32">
                <!-- 2. Page Header Section -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="قائمة الموكلين" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                        <TextBlock Text="عرض وإدارة جميع الموكلين المسجلين في المكتب" FontSize="15" Foreground="{StaticResource TextGray}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Command="{Binding FilterCommand}" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="16,8" Margin="0,0,12,0" Cursor="Hand" Foreground="{StaticResource TextDark}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="تصفية النتائج" Margin="0,0,8,0" FontWeight="SemiBold"/>
                                <TextBlock Text="▼" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportCommand}" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="16,8" Cursor="Hand" Foreground="{StaticResource TextDark}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="تصدير القائمة" Margin="0,0,8,0" FontWeight="SemiBold"/>
                                <TextBlock Text="📤" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
                <!-- 3. Client Cards Grid -->
                <ItemsControl ItemsSource="{Binding Clients}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" Margin="-12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ModernCard}" Margin="12" Padding="0" BorderThickness="1" BorderBrush="#F1F5F9">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Card Top Section -->
                                    <Border Grid.Row="0" Padding="24,24,24,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Avatar -->
                                                <ColumnDefinition Width="*"/>    <!-- Name & Status -->
                                                <ColumnDefinition Width="Auto"/> <!-- Edit/Archive Icons -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar/User Icon -->
                                            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="12" Background="#EFF6FF">
                                                <TextBlock Text="👤" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" Foreground="#3B82F6"/>
                                            </Border>

                                            <!-- Name and Status Badge -->
                                            <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="18" Foreground="{StaticResource TextDark}" TextWrapping="Wrap"/>
                                                <Border Background="{Binding StatusBgColor}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" Margin="0,8,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⚖️" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ActiveCasesCount, StringFormat='\{0\} قضية نشطة'}" Foreground="{Binding StatusColor}" FontSize="11" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <!-- Action Icons (Left in RTL) -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                                <Button Background="Transparent" BorderThickness="0" Margin="0,0,12,0" Cursor="Hand" ToolTip="تعديل">
                                                    <TextBlock Text="✏️" FontSize="16" Foreground="{StaticResource TextGray}"/>
                                                </Button>
                                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="أرشفة">
                                                    <TextBlock Text="📁" FontSize="16" Foreground="{StaticResource TextGray}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Card Info Section (Blueish background) -->
                                    <Border Grid.Row="1" Padding="24" Background="#F8FAFC" BorderBrush="#F1F5F9" BorderThickness="0,1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                <TextBlock Text="📞" Foreground="{StaticResource TextGray}" Width="28" FontSize="14"/>
                                                <TextBlock Text="{Binding PhoneNumber}" Foreground="{StaticResource TextDark}" FontSize="14" FontWeight="Medium"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                <TextBlock Text="📇" Foreground="{StaticResource TextGray}" Width="28" FontSize="14"/>
                                                <TextBlock Text="{Binding NationalId}" Foreground="{StaticResource TextDark}" FontSize="14" FontWeight="Medium"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📍" Foreground="{StaticResource TextGray}" Width="28" FontSize="14"/>
                                                <TextBlock Text="{Binding Address}" Foreground="{StaticResource TextGray}" FontSize="13" TextWrapping="Wrap" LineHeight="20"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Card Bottom Section -->
                                    <Border Grid.Row="2" Padding="24,16">
                                        <Grid>
                                            <TextBlock Text="{Binding LastAction, StringFormat='آخر تحديث: \{0\}'}" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            
                                            <Button HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.ViewProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="عرض الملف الشخصي" Foreground="{StaticResource TextDark}" FontWeight="Bold" FontSize="13" Margin="0,0,8,0"/>
                                                    <TextBlock Text="←" Foreground="{StaticResource TextDark}" VerticalAlignment="Center" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 4. Detailed Table Section -->
                <Border Style="{StaticResource ModernCard}" Margin="0,48,0,0" Padding="0" BorderBrush="#F1F5F9">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Table Top Row: Title and Status Dots -->
                        <Border Grid.Row="0" Padding="24,24" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="نظرة عامة مفصلة" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextDark}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="24,0,0,0">
                                        <Ellipse Width="10" Height="10" Fill="{StaticResource AccentGreen}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="نشط" Foreground="{StaticResource TextGray}" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Fill="{StaticResource TextGray}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="مؤرشف" Foreground="{StaticResource TextGray}" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Clients}" AutoGenerateColumns="False" 
                                  Background="White" BorderThickness="0" HeadersVisibility="Column" 
                                  GridLinesVisibility="None" RowBackground="White" AlternatingRowBackground="#FAFAFA"
                                  IsReadOnly="True" Margin="0">
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="24,16"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="MinHeight" Value="64"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="24,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <!-- Client Info -->
                                <DataGridTemplateColumn Header="اسم الموكل" Width="2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="36" Height="36" CornerRadius="8" Background="#111827" Margin="0,0,16,0">
                                                    <TextBlock Text="{Binding Initial}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                                                </Border>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center" FontSize="14"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- National ID -->
                                <DataGridTextColumn Header="الرقم القومي" Binding="{Binding NationalId}" Width="1.5*"/>

                                <!-- Phone -->
                                <DataGridTextColumn Header="رقم الهاتف" Binding="{Binding PhoneNumber}" Width="1.5*"/>

                                <!-- Cases -->
                                <DataGridTemplateColumn Header="القضايا" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F3F4F6" CornerRadius="12" Padding="14,6" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding ActiveCasesCount, StringFormat='\{0\} قضايا'}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextDark}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Last Action -->
                                <DataGridTextColumn Header="آخر إجراء" Binding="{Binding LastAction}" Width="1.5*"/>

                                <!-- Actions -->
                                <DataGridTemplateColumn Header="الإجراءات" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Background="Transparent" BorderThickness="0" Margin="6,0" Cursor="Hand" ToolTip="عرض">
                                                    <TextBlock Text="👁️" FontSize="16" Foreground="#10B981"/>
                                                </Button>
                                                <Button Background="Transparent" BorderThickness="0" Margin="6,0" Cursor="Hand" ToolTip="حذف">
                                                    <TextBlock Text="🗑️" FontSize="16" Foreground="#EF4444"/>
                                                </Button>
                                                <Button Background="Transparent" BorderThickness="0" Margin="6,0" Cursor="Hand" ToolTip="تعديل">
                                                    <TextBlock Text="✏️" FontSize="16" Foreground="{StaticResource TextGray}"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- 5. Pagination (matching image) -->
                        <Border Grid.Row="2" Padding="24,20" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Background="White">
                            <Grid>
                                <TextBlock Text="عرض 1-10 من أصل 124 موكل" Foreground="{StaticResource TextGray}" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="13" FontWeight="Medium"/>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="السابق" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="16,8" Margin="0,0,12,0" FontSize="13" FontWeight="SemiBold"/>
                                    <Button Content="1" Background="#111827" Foreground="White" BorderThickness="0" Padding="14,8" Margin="0,0,6,0" FontSize="13" FontWeight="Bold" Width="40"/>
                                    <Button Content="2" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="14,8" Margin="0,0,6,0" FontSize="13" FontWeight="Bold" Width="40"/>
                                    <Button Content="التالي" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="16,8" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
        </Grid>

        <!-- 6. Add Client Pop-up Overlay -->
        <Grid x:Name="Overlay" Visibility="{Binding IsAddClientDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="Black" Opacity="0.4"/>
            
            <!-- Dialog Content -->
            <Border Background="White" CornerRadius="12" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Body -->
                        <RowDefinition Height="Auto"/> <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="{StaticResource DialogHeaderBg}" CornerRadius="12,12,0,0" Padding="24,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="إضافة موكل جديد" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="أدخل بيانات الموكل القانونية للبدء" Foreground="#9CA3AF" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="✕" Foreground="White" Background="Transparent" BorderThickness="0" FontSize="18" VerticalAlignment="Top" Margin="0,-10,-10,0" Cursor="Hand" Command="{Binding CloseDialogCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <StackPanel Grid.Row="1" Margin="24,32">
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Style="{StaticResource DialogLabel}">
                                    <Run Text="اسم الموكل"/> <Run Text="*" Foreground="{StaticResource ErrorRed}"/>
                                </TextBlock>
                                <TextBox Style="{StaticResource DialogTextBox}" Tag="مثال: أحمد محمد علي"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource DialogLabel}">
                                    <Run Text="رقم التليفون"/> <Run Text="*" Foreground="{StaticResource ErrorRed}"/>
                                </TextBlock>
                                <TextBox Style="{StaticResource DialogTextBox}" Tag="xxxxxxxxxx" BorderBrush="{StaticResource ErrorRed}" BorderThickness="1"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Style="{StaticResource DialogLabel}" Text="الرقم القومي (اختياري)"/>
                            <TextBox Style="{StaticResource DialogTextBox}" Tag="2900101xxxxxxx"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Style="{StaticResource DialogLabel}" Text="العنوان (اختياري)"/>
                            <TextBox Style="{StaticResource DialogTextBox}" Tag="رقم العقار، اسم الشارع، المحافظة"/>
                        </StackPanel>

                        <Border Background="#F9FAFB" CornerRadius="8" Padding="16,12" BorderBrush="#F1F5F9" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="16,0">
                                    <TextBlock Text="توكيل رسمي" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextDark}"/>
                                    <TextBlock Text="هل يوجد توكيل رسمي مسجل لهذا الموكل؟" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Footer -->
                    <Border Grid.Row="2" Background="#F8FAFC" Padding="24,20" CornerRadius="0,0,12,12" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Width="180" Height="44" Background="#059669" Foreground="White" Content="حفظ البيانات" FontWeight="Bold"/>
                            <Button Width="100" Height="44" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Margin="12,0,0,0" Content="إلغاء" Command="{Binding CloseDialogCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
