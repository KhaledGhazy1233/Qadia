<Window x:Class="Qadia.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Qadia.ViewModels"
        Title="Qadia Command Center" 
        Width="1440" Height="950"
        Background="#F3F4F6" 
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="4" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="SidebarBg" Color="#111827"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="HoverGreen" Color="#059669"/>
        <SolidColorBrush x:Key="TextDark" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextGray" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderGray" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="BlueHighlight" Color="#3B82F6"/>
        
        <!-- Styles -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="15" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="16,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Margin="0,0,12,0" FontSize="16"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="NewFileBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="16,24,16,16"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="+" Margin="0,0,8,0" FontSize="18" FontWeight="Regular"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource HoverGreen}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bgBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bgBorder" Property="Background" Value="{StaticResource HoverGreen}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Agenda DataGrid Style -->
        <Style x:Key="AgendaDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F9FAFB"/>
                        <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="16,12"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="MinHeight" Value="75"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderGray}"/>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="16,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Custom TitleBar -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="White">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" WindowChrome.IsHitTestVisibleInChrome="True" VerticalAlignment="Stretch">
                <!-- Close Button -->
                <Button Width="46" Background="Transparent" BorderThickness="0" Click="BtnClose_Click" Cursor="Hand">
                    <TextBlock Text="✕" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <!-- Maximize Button -->
                <Button Width="46" Background="Transparent" BorderThickness="0" Click="BtnMaximize_Click" Cursor="Hand">
                    <TextBlock Text="⬜" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <!-- Minimize Button -->
                <Button Width="46" Background="Transparent" BorderThickness="0" Click="BtnMinimize_Click" Cursor="Hand">
                    <TextBlock Text="—" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 1. Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Section -->
                <StackPanel Grid.Row="0" Margin="24,32,24,24" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="مركز التحكم" Foreground="White" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource SidebarBtn}" Content="الرئيسية" Tag="🏠" Foreground="White" Background="#1F2937" Command="{Binding HomeCommand}"/>
                    <Button Style="{StaticResource SidebarBtn}" Content="الموكلون" Tag="👥" Command="{Binding ClientsCommand}"/>
                    <Button Style="{StaticResource SidebarBtn}" Content="القضايا" Tag="⚖️" Command="{Binding CasesCommand}"/>
                    <Button Style="{StaticResource SidebarBtn}" Content="الجلسات" Tag="📅" Command="{Binding SessionsCommand}"/>
                    <Button Style="{StaticResource SidebarBtn}" Content="الإعدادات" Tag="⚙️" Command="{Binding SettingsCommand}"/>
                </StackPanel>

                <!-- New File Button -->
                <Button Grid.Row="2" Style="{StaticResource NewFileBtn}" Content="ملف جديد" VerticalAlignment="Bottom" Command="{Binding NewFileCommand}"/>

                <!-- User Profile -->
                <Border Grid.Row="3" Background="#1F2937" Padding="16,12" Margin="16,0,16,24" CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserName}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="{Binding UserRole}" Foreground="#9CA3AF" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="36" Height="36" Background="{StaticResource AccentGreen}" CornerRadius="18" Margin="12,0,0,0">
                            <TextBlock Text="{Binding UserInitials}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                        </Border>
                        <Button Grid.Column="2" Content="↪️" Background="Transparent" Foreground="#9CA3AF" BorderThickness="0" FontSize="16" Margin="12,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="24">
            
            <!-- Dashboard View (Visible when CurrentViewModel is null) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentViewModel}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Grid Margin="0,0,16,0">
                    
                    <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Top Bar -->
                    <RowDefinition Height="Auto"/> <!-- Greeting & Stats -->
                    <RowDefinition Height="*"/>    <!-- Main Layout -->
                    <RowDefinition Height="Auto"/> <!-- Bottom Cards -->
                </Grid.RowDefinitions>

                <!-- Top Bar -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Search -->
                    <Border Grid.Column="0" HorizontalAlignment="Left" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="8" Padding="16,8" Width="500">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="{StaticResource TextGray}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBox BorderThickness="0" Background="Transparent" Foreground="{StaticResource TextDark}" VerticalContentAlignment="Center" Width="450" Text="بحث سريع في القضايا، الموكلين، أو المستندات..."/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Style="{StaticResource ActionButton}" Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" Margin="0,0,8,0"/>
                                <TextBlock Text="إضافة جلسة سريعة"/>
                            </StackPanel>
                        </Button>
                        <Button Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="12,8" Margin="16,0,0,0" Cursor="Hand">
                            <TextBlock Text="🔔" Foreground="{StaticResource TextGray}"/>
                        </Button>
                        <Button Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="12,8" Margin="16,0,0,0" Cursor="Hand">
                            <TextBlock Text="📅" Foreground="{StaticResource TextGray}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Greeting & Stats -->
                <Grid Grid.Row="1" Margin="0,0,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="صباح الخير، أ/ أحمد" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                        <TextBlock Text="لديك 8 جلسات عمل مدرجة لهذا اليوم." FontSize="14" Foreground="{StaticResource TextGray}" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Stat 1 -->
                        <Border Grid.Column="0" Style="{StaticResource ModernCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="جلسات اليوم" Foreground="{StaticResource TextGray}" FontSize="14"/>
                                    <TextBlock Text="08" FontSize="36" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,8,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Width="48" Height="48" Background="#1F2937" CornerRadius="8" VerticalAlignment="Center">
                                    <TextBlock Text="📅" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Stat 2 -->
                        <Border Grid.Column="2" Style="{StaticResource ModernCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="إجراءات معلقة" Foreground="{StaticResource TextGray}" FontSize="14"/>
                                    <TextBlock Text="12" FontSize="36" FontWeight="Bold" Foreground="#EF4444" Margin="0,8,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Width="48" Height="48" Background="#FEE2E2" CornerRadius="8" VerticalAlignment="Center">
                                    <TextBlock Text="📄" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- Stat 3 -->
                        <Border Grid.Column="4" Style="{StaticResource ModernCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="قضايا نشطة" Foreground="{StaticResource TextGray}" FontSize="14"/>
                                    <TextBlock Text="154" FontSize="36" FontWeight="Bold" Foreground="{StaticResource AccentGreen}" Margin="0,8,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1" Width="48" Height="48" Background="#D1FAE5" CornerRadius="8" VerticalAlignment="Center">
                                    <TextBlock Text="⚖️" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Main Layout -->
                <Grid Grid.Row="2" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Right Column: Agenda (Column 0 in RTL) -->
                    <Border Grid.Column="0" Style="{StaticResource ModernCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header -->
                            <Grid Grid.Row="0" Margin="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📋" FontSize="20" Margin="12,0,0,0"/>
                                    <TextBlock Text="أجندة أعمال اليوم" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                                    <!-- Pill next to Title -->
                                    <Border Background="#E2E8F0" CornerRadius="12" Padding="12,4" Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="24 أكتوبر 2023" Foreground="#475569" FontSize="14" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Button on far edge -->
                                <Button Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Padding="12,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="تغيير التاريخ" Margin="0,0,8,0"/>
                                        <TextBlock Text="📅"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            
                            <!-- DataGrid -->
                            <DataGrid Grid.Row="1" ItemsSource="{Binding TodaySessions}" Style="{StaticResource AgendaDataGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="الوقت" Binding="{Binding Time}" Width="Auto"/>
                                    <DataGridTextColumn Header="الموكل والقضية" Binding="{Binding ClientCase}" Width="2*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="المحكمة" Binding="{Binding Court}" Width="1.5*"/>
                                    <DataGridTextColumn Header="المتطلبات" Binding="{Binding Requirements}" Width="*"/>
                                    <!-- Using Template for decision to mimic input -->
                                    <DataGridTemplateColumn Header="القرار" Width="1.5*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel VerticalAlignment="Center">
                                                    <Border Background="#F0F4F8" CornerRadius="8" Padding="16,8">
                                                        <TextBlock Text="{Binding Decision}" Foreground="#6B7280" HorizontalAlignment="Center" FontSize="12"/>
                                                    </Border>
                                                    <Border BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="4" Padding="8,4" Background="White" Margin="0,4,0,0">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowDatePicker}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <TextBlock Text="{Binding DecisionDate}" Foreground="{StaticResource TextDark}" HorizontalAlignment="Left" FontSize="12"/>
                                                            <TextBlock Text="📅" HorizontalAlignment="Right" FontSize="12"/>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="الحالة" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <!-- Background with Opacity -->
                                                    <Border CornerRadius="16" Background="{Binding StatusColor}" Opacity="0.1" />
                                                    <!-- Content -->
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,8">
                                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="Bold" FontSize="12"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            
                            <!-- Footer Button -->
                            <Button Grid.Row="2" Background="#F9FAFB" BorderThickness="0" Foreground="{StaticResource TextDark}" FontWeight="SemiBold" Padding="0,16" VerticalAlignment="Bottom">
                                <TextBlock Text="عرض جميع جلسات اليوم"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Left Column: Alerts (Column 2 in RTL) -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="❗" Foreground="#EF4444" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" VerticalAlignment="Center"/>
                                <TextBlock Text="تنبيهات عاجلة" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Background="#EF4444" CornerRadius="12" Width="24" Height="24" HorizontalAlignment="Left">
                                <TextBlock Text="4" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        
                        <!-- Alerts List -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding UrgentAlerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="4" Margin="0,0,0,12" ClipToBounds="True">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" Opacity="0.02" BlurRadius="5" ShadowDepth="1"/>
                                        </Border.Effect>
                                        <Grid>
                                            <!-- Faint Background -->
                                            <Border Background="{Binding BorderColor}" Opacity="0.03" />
                                            <!-- Right colored line -->
                                            <Border BorderBrush="{Binding BorderColor}" BorderThickness="0,0,4,0"/>
                                            <StackPanel Margin="16">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="{Binding BorderColor}"/>
                                                <TextBlock Text="{Binding Details}" Foreground="{StaticResource TextGray}" FontSize="12" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Button Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderGray}" BorderThickness="1" Foreground="{StaticResource TextGray}" Padding="0,12" Margin="0,0,0,24">
                            <TextBlock Text="عرض جميع التنبيهات"/>
                        </Button>
                        
                        <!-- Efficiency Card -->
                        <Border Grid.Row="3" Background="#111827" CornerRadius="16" Padding="24">
                            <StackPanel>
                                <TextBlock Text="كفاءة العمليات" Foreground="#9CA3AF" FontSize="12"/>
                                <!-- Fake Chart -->
                                <Grid Height="80" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#374151" Margin="4,40,4,0" CornerRadius="2"/>
                                    <Border Grid.Column="1" Background="#374151" Margin="4,20,4,0" CornerRadius="2"/>
                                    <Border Grid.Column="2" Background="{StaticResource AccentGreen}" Margin="4,0,4,0" CornerRadius="2"/>
                                    <Border Grid.Column="3" Background="#374151" Margin="4,30,4,0" CornerRadius="2"/>
                                    <Border Grid.Column="4" Background="#374151" Margin="4,50,4,0" CornerRadius="2"/>
                                    <Border Grid.Column="5" Background="#374151" Margin="4,25,4,0" CornerRadius="2"/>
                                    <Border Grid.Column="6" Background="#374151" Margin="4,15,4,0" CornerRadius="2"/>
                                </Grid>
                                <TextBlock Text="92%" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,16,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="📈" Foreground="{StaticResource AccentGreen}" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="معدل الإنجاز الأسبوعي" Foreground="#9CA3AF" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Bottom Cards -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource ModernCard}">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="المستندات الأخيرة" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                                <TextBlock Text="3 ملفات جديدة" Foreground="{StaticResource TextGray}" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="📄" FontSize="24" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ModernCard}">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="المطالبات المالية" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                                <TextBlock Text="فواتير مستحقة" Foreground="{StaticResource TextGray}" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="💵" FontSize="24" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource ModernCard}">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="المكتبة القانونية" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                                <TextBlock Text="تحديثات التشريعات" Foreground="{StaticResource TextGray}" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="📚" FontSize="24" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" Style="{StaticResource ModernCard}">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="الرسائل" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                                <TextBlock Text="محادثات نشطة" Foreground="{StaticResource TextGray}" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Text="💬" FontSize="24" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
            </ScrollViewer>

            <!-- Dynamic Views (e.g. ClientsView) -->
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Grid>
    </Grid>
</Window>