<Application x:Class="Qadia.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Qadia.ViewModels"
             xmlns:views="clr-namespace:Qadia.Views">
    <Application.Resources>
        <!-- DataTemplates for Dynamic Routing -->
        <DataTemplate DataType="{x:Type vm:ClientsViewModel}">
            <views:ClientsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CasesViewModel}">
            <views:CasesView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SessionsViewModel}">
            <views:SessionsView />
        </DataTemplate>

        <SolidColorBrush x:Key="SidebarBg" Color="#1E2533"/>
        <SolidColorBrush x:Key="MainBg" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="AccentGold" Color="#F59E0B"/>
        <SolidColorBrush x:Key="TextHeader" Color="#1E2533"/>
        <SolidColorBrush x:Key="TextSub" Color="#94A3B8"/>

        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.04" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D3748"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>